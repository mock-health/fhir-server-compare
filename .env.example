# Copy to .env and fill in the values for the servers you want to run.
# docker-compose.yml reads this file automatically.

# --- Aidbox ---
# Free developer license, no credit card. Register at https://aidbox.app/signup
# and paste the license string below. Aidbox won't start without it on a
# licensed tier; leave blank on a tier that doesn't require one.
AIDBOX_LICENSE=

# Optional: change the default Basic-auth client credentials compare.py uses.
# If unset, defaults to basic-client / secret (also matches servers.yaml).
AIDBOX_CLIENT_ID=basic-client
AIDBOX_CLIENT_SECRET=secret
AIDBOX_ADMIN_PASSWORD=password

# Postgres password for the Aidbox backing database (stock postgres:18 as of
# 2026-04-24 — the `healthsamurai/aidboxdb` image was deprecated upstream).
AIDBOX_DB_PASSWORD=aidbox

# --- Medplum ---
# Client credentials for the bootstrap project. After `docker compose up`,
# run Medplum's first-time setup (see README) to provision a ClientApplication
# and paste its credentials here.
MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=

# --- Microsoft FHIR Server ---
# SQL Server 2022 requires a complex password. Default works; change if you
# re-use this compose stack in a shared environment.
MSSQL_SA_PASSWORD=Fhir_Compare_Pass1!
