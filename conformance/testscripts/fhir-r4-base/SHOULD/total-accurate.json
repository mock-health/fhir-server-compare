{
  "resourceType": "TestScript",
  "id": "fhir-r4-base-total-accurate",
  "url": "https://mock.health/conformance/testscripts/fhir-r4-base-total-accurate",
  "name": "FhirR4BaseTotalAccurate",
  "title": "FHIR R4 — _total=accurate populates Bundle.total",
  "status": "active",
  "date": "2026-04-19",
  "publisher": "mock.health",
  "description": "Per FHIR R4 search.html#total, _total=accurate is a hint to populate Bundle.total with the exact match count. A server SHOULD honor this for clients that need a count for pagination UIs. We don't assert the count value (depends on data), only that the request succeeds.",
  "relatedArtifact": [
    {
      "type": "documentation",
      "label": "FHIR R4 — _total=accurate",
      "url": "https://hl7.org/fhir/R4/search.html#total"
    }
  ],
  "test": [
    {
      "id": "should-honor-total-accurate",
      "name": "_total=accurate returns 200",
      "action": [
        {
          "operation": {
            "type": {
              "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
              "code": "search"
            },
            "resource": "Observation",
            "encodeRequestUrl": false,
            "params": "?_count=1&_total=accurate"
          }
        },
        {
          "assert": {
            "label": "responseCode is 200",
            "operator": "equals",
            "responseCode": "200"
          }
        }
      ]
    }
  ]
}
