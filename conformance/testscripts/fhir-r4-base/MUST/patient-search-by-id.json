{
  "resourceType": "TestScript",
  "id": "fhir-r4-base-patient-search-by-id",
  "url": "https://mock.health/conformance/testscripts/fhir-r4-base-patient-search-by-id",
  "name": "FhirR4BasePatientSearchById",
  "title": "FHIR R4 — Patient search supports the _id parameter",
  "status": "active",
  "date": "2026-04-19",
  "publisher": "mock.health",
  "description": "Per FHIR R4 §3.1.1 search parameters for all resources, every resource MUST support the _id search parameter (search.html#all). Searching for a non-existent _id SHALL return a Bundle (empty) — not 4xx, not 5xx. The Bundle is the canonical 'no results' shape.",
  "relatedArtifact": [
    {
      "type": "documentation",
      "label": "FHIR R4 — _id search parameter (all resources)",
      "url": "https://hl7.org/fhir/R4/search.html#all"
    }
  ],
  "test": [
    {
      "id": "must-search-by-id-returns-bundle",
      "name": "GET /Patient?_id=non-existent returns 200 + Bundle",
      "action": [
        {
          "operation": {
            "type": {
              "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
              "code": "search"
            },
            "resource": "Patient",
            "encodeRequestUrl": false,
            "params": "?_id=this-id-cannot-exist-conformance-test-9f3e2a&_count=1"
          }
        },
        {
          "assert": {
            "label": "responseCode is 200",
            "operator": "equals",
            "responseCode": "200"
          }
        },
        {
          "assert": {
            "label": "responseBody is a Bundle",
            "operator": "matchesRegex",
            "responseBody": "\"resourceType\"\\s*:\\s*\"Bundle\""
          }
        }
      ]
    }
  ]
}
