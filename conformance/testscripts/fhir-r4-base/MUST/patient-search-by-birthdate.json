{
  "resourceType": "TestScript",
  "id": "fhir-r4-base-patient-search-by-birthdate",
  "url": "https://mock.health/conformance/testscripts/fhir-r4-base-patient-search-by-birthdate",
  "name": "FhirR4BasePatientSearchByBirthdate",
  "title": "FHIR R4 — Patient search supports date prefixes (gt/lt/ge/le)",
  "status": "active",
  "date": "2026-04-19",
  "publisher": "mock.health",
  "description": "Per FHIR R4 search.html#date, date search parameters MUST accept `eq`, `ne`, `gt`, `lt`, `ge`, `le` prefixes. The `birthdate` parameter on Patient is the canonical example (used for age-range queries in every clinical app). Servers that ignore the prefix or return 400 fail core search semantics.",
  "relatedArtifact": [
    {
      "type": "documentation",
      "label": "FHIR R4 — search on a date parameter (prefixes)",
      "url": "https://hl7.org/fhir/R4/search.html#date"
    }
  ],
  "test": [
    {
      "id": "must-date-prefix-ge",
      "name": "GET /Patient?birthdate=ge1900-01-01 returns 200 + Bundle (date prefix supported)",
      "action": [
        {
          "operation": {
            "type": {
              "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
              "code": "search"
            },
            "resource": "Patient",
            "encodeRequestUrl": false,
            "params": "?birthdate=ge1900-01-01&_count=1"
          }
        },
        {
          "assert": {
            "label": "responseCode is 200",
            "operator": "equals",
            "responseCode": "200"
          }
        },
        {
          "assert": {
            "label": "responseBody is a Bundle",
            "operator": "matchesRegex",
            "responseBody": "\"resourceType\"\\s*:\\s*\"Bundle\""
          }
        }
      ]
    }
  ]
}
