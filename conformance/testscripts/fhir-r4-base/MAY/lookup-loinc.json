{
  "resourceType": "TestScript",
  "id": "fhir-r4-base-lookup-loinc",
  "url": "https://mock.health/conformance/testscripts/fhir-r4-base-lookup-loinc",
  "name": "FhirR4BaseLookupLoinc",
  "title": "FHIR R4 — CodeSystem/$lookup operation present",
  "status": "active",
  "date": "2026-04-19",
  "publisher": "mock.health",
  "description": "CodeSystem/$lookup is an OPTIONAL terminology operation. The most divergent FHIR operation across servers per the matrix — five distinct status codes across seven servers. The MAY-pass criterion is 'NOT 5xx' — operation is at least routable to a clean error.",
  "relatedArtifact": [
    {
      "type": "documentation",
      "label": "FHIR R4 — CodeSystem/$lookup operation",
      "url": "https://hl7.org/fhir/R4/codesystem-operation-lookup.html"
    }
  ],
  "test": [
    {
      "id": "may-route-lookup",
      "name": "CodeSystem/$lookup returns clean 2xx or 4xx (no 5xx)",
      "action": [
        {
          "operation": {
            "type": {
              "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
              "code": "search"
            },
            "resource": "CodeSystem",
            "encodeRequestUrl": false,
            "params": "/$lookup?system=http://loinc.org&code=85354-9"
          }
        },
        {
          "assert": {
            "label": "responseCode not in 5xx range",
            "operator": "notIn",
            "responseCode": "500,501,502,503,504,505"
          }
        }
      ]
    }
  ]
}
