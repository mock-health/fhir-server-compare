{
  "resourceType": "TestScript",
  "id": "bulk-data-v2-patient-export-returns-202",
  "url": "https://mock.health/conformance/testscripts/bulk-data-v2-patient-export-returns-202",
  "name": "BulkDataV2PatientExportReturns202",
  "title": "Bulk Data v2 — Patient/$export returns 202 Accepted",
  "status": "active",
  "date": "2026-04-19",
  "publisher": "mock.health",
  "description": "Per Bulk Data Access IG v2 §3.2, Patient-level $export with Prefer: respond-async SHALL return 202 Accepted to indicate the asynchronous job has been queued. This is the foundational kick-off contract — without it, a Bulk Data client has no async handle to poll.",
  "relatedArtifact": [
    {
      "type": "documentation",
      "label": "Bulk Data v2 §3.2 — kick-off request",
      "url": "https://hl7.org/fhir/uv/bulkdata/STU2/export.html#bulk-data-kick-off-request"
    }
  ],
  "test": [
    {
      "id": "must-kickoff-202",
      "name": "Patient/$export with Prefer: respond-async returns 202",
      "action": [
        {
          "operation": {
            "type": {
              "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
              "code": "search"
            },
            "resource": "Patient",
            "encodeRequestUrl": false,
            "params": "/$export",
            "requestHeader": [
              {
                "field": "Prefer",
                "value": "respond-async"
              },
              {
                "field": "Accept",
                "value": "application/fhir+json"
              }
            ]
          }
        },
        {
          "assert": {
            "label": "responseCode is 202 Accepted",
            "operator": "equals",
            "responseCode": "202"
          }
        }
      ]
    }
  ]
}
