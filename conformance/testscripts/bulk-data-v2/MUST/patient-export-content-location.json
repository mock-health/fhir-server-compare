{
  "resourceType": "TestScript",
  "id": "bulk-data-v2-patient-export-content-location",
  "url": "https://mock.health/conformance/testscripts/bulk-data-v2-patient-export-content-location",
  "name": "BulkDataV2PatientExportContentLocation",
  "title": "Bulk Data v2 — Patient/$export 202 includes Content-Location header",
  "status": "active",
  "date": "2026-04-19",
  "publisher": "mock.health",
  "description": "Per Bulk Data Access IG v2 §3.2.2, the 202 Accepted response from kick-off SHALL include a Content-Location header pointing to the polling status URL. This is the only handle the client has to track the async job — its absence makes the 202 useless.",
  "relatedArtifact": [
    {
      "type": "documentation",
      "label": "Bulk Data v2 §3.2.2 — kick-off response (success)",
      "url": "https://hl7.org/fhir/uv/bulkdata/STU2/export.html#response---success"
    }
  ],
  "test": [
    {
      "id": "must-kickoff-content-location",
      "name": "Patient/$export 202 carries non-empty Content-Location",
      "action": [
        {
          "operation": {
            "type": {
              "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
              "code": "search"
            },
            "resource": "Patient",
            "encodeRequestUrl": false,
            "params": "/$export",
            "requestHeader": [
              {
                "field": "Prefer",
                "value": "respond-async"
              },
              {
                "field": "Accept",
                "value": "application/fhir+json"
              }
            ]
          }
        },
        {
          "assert": {
            "label": "Content-Location header is present",
            "operator": "notEmpty",
            "headerField": "Content-Location"
          }
        }
      ]
    }
  ]
}
