{
  "resourceType": "TestScript",
  "id": "bulk-data-v2-system-export-discoverable",
  "url": "https://mock.health/conformance/testscripts/bulk-data-v2-system-export-discoverable",
  "name": "BulkDataV2SystemExportDiscoverable",
  "title": "Bulk Data v2 — system-level $export route is discoverable",
  "status": "active",
  "date": "2026-04-19",
  "publisher": "mock.health",
  "description": "Per Bulk Data Access IG v2 §3.4, system-level $export (the entire server's data) is OPTIONAL — it's a heavy operation typically only enabled for back-of-house ETL. We test discoverability by hitting / $export — a server with this enabled returns 202; a server without returns 404. 5xx indicates a misconfigured implementation.",
  "relatedArtifact": [
    {
      "type": "documentation",
      "label": "Bulk Data v2 §3.4 — system-level export endpoint",
      "url": "https://hl7.org/fhir/uv/bulkdata/STU2/export.html#endpoint---system-level-export"
    }
  ],
  "test": [
    {
      "id": "may-route-system-export",
      "name": "System-level /$export endpoint is routed (not 404)",
      "action": [
        {
          "operation": {
            "type": {
              "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
              "code": "search"
            },
            "encodeRequestUrl": false,
            "params": "/$export",
            "requestHeader": [
              {
                "field": "Prefer",
                "value": "respond-async"
              },
              {
                "field": "Accept",
                "value": "application/fhir+json"
              }
            ]
          }
        },
        {
          "assert": {
            "label": "responseCode is not 404",
            "operator": "notEquals",
            "responseCode": "404"
          }
        }
      ]
    }
  ]
}
