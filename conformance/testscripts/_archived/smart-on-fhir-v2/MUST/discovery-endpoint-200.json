{
  "resourceType": "TestScript",
  "id": "smart-on-fhir-v2-discovery-endpoint-200",
  "url": "https://mock.health/conformance/testscripts/smart-on-fhir-v2-discovery-endpoint-200",
  "name": "SmartOnFhirV2DiscoveryEndpoint200",
  "title": "SMART on FHIR v2 — /.well-known/smart-configuration returns 200",
  "status": "active",
  "date": "2026-04-19",
  "publisher": "mock.health",
  "description": "Per SMART App Launch IG v2 §5.1, servers SHALL expose a SMART configuration document at <fhir-base>/.well-known/smart-configuration. This is the canonical discovery surface — without it, conformant SMART apps cannot bootstrap against the server.",
  "test": [
    {
      "id": "must-discovery-200",
      "name": "GET /.well-known/smart-configuration returns 200",
      "action": [
        {
          "operation": {
            "type": {
              "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
              "code": "search"
            },
            "encodeRequestUrl": false,
            "params": "/.well-known/smart-configuration",
            "requestHeader": [
              { "field": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "assert": {
            "label": "responseCode is 200",
            "operator": "equals",
            "responseCode": "200"
          }
        }
      ]
    }
  ]
}
